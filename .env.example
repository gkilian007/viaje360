# Viaje360 environment template
# Copy to .env.local for local dev.
# For staging/prod, set the same keys in your deployment platform.

# --- Required runtime secrets ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GEMINI_API_KEY=your-gemini-api-key

# --- Optional runtime secrets ---
# Enables Google Places as primary provider only when FEATURE_GOOGLE_PLACES=true.
GOOGLE_PLACES_API_KEY=

# Explicitly allow anonymous fallback outside dev/test only if you really want it.
VIAJE360_ALLOW_ANONYMOUS_FALLBACK=false

# --- Feature flags ---
# Defaults in code:
# FEATURE_GOOGLE_PLACES=false
# FEATURE_OPEN_METEO=true
# FEATURE_PLACES_CACHE=false
# FEATURE_WEATHER_CACHE=false
# FEATURE_RATE_LIMITING=true
FEATURE_GOOGLE_PLACES=false
FEATURE_OPEN_METEO=true
FEATURE_PLACES_CACHE=false
FEATURE_WEATHER_CACHE=false
FEATURE_RATE_LIMITING=false
