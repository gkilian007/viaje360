{
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": false
    }
  },
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "functions": {
    "src/app/api/itinerary/generate/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/itinerary/adapt/route.ts": {
      "maxDuration": 45
    },
    "src/app/api/chat/route.ts": {
      "maxDuration": 20
    },
    "src/app/api/proactive/evaluate/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/cron/unified/route.ts": {
      "maxDuration": 45
    },
    "src/app/api/cron/nightly/route.ts": {
      "maxDuration": 45
    }
  },
  "crons": [
    {
      "path": "/api/cron/unified",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/nightly",
      "schedule": "0 20 * * *"
    }
  ]
}
